# TravelGo Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control

# ============================================================================
# Flask Configuration
# ============================================================================

# Secret key for session management (CHANGE THIS IN PRODUCTION!)
# Generate a secure key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-in-production

# ============================================================================
# AWS Configuration
# ============================================================================

# Enable or disable AWS integration (set to 'true' or 'false')
# If false, the application will use in-memory storage
USE_AWS=false

# AWS Region where your resources are located
AWS_REGION=us-east-1

# AWS SNS Topic ARN for email notifications
# Format: arn:aws:sns:region:account-id:topic-name
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:TravelGo-Notifications

# ============================================================================
# AWS Credentials
# ============================================================================
# Note: It's recommended to use AWS CLI credential profiles or IAM roles
# instead of hardcoding credentials here. If you must use credentials here,
# ensure this file is never committed to version control.

# AWS_ACCESS_KEY_ID=your_access_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_key_here

# ============================================================================
# DynamoDB Table Names (Optional - defaults to TravelGo_Users and TravelGo_Bookings)
# ============================================================================

USERS_TABLE=TravelGo_Users
BOOKINGS_TABLE=TravelGo_Bookings

# ============================================================================
# Application Configuration
# ============================================================================

# Flask environment (development or production)
FLASK_ENV=development

# Enable Flask debug mode (true or false)
# WARNING: Never enable debug mode in production!
FLASK_DEBUG=true

# Application port
PORT=5000
